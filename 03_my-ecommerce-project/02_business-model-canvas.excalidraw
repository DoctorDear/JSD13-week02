    {
      "id": "ePgFI_3PM1q_UK4RAuw6r",
      "type": "text",
      "x": -1207.1828816731772,
      "y": 486.2995368904534,
      "width": 509.318359375,
      "height": 756.0000000000001,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
